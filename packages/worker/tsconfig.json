{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types/2023-07-01"]
  },
  "include": ["src/**/*.js"],
  "exclude": ["src/__tests__/**", ".wrangler/**", "node_modules/**"]
}
