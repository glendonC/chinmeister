{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2024"],
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "./cli.jsx",
    "./cli.tsx",
    "./lib/**/*.js",
    "./lib/**/*.jsx",
    "./lib/**/*.ts",
    "./lib/**/*.tsx",
    "./vitest.config.js"
  ],
  "exclude": ["./dist", "./node_modules", "./coverage"]
}
