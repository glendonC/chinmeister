{
  "name": "chinwag",
  "version": "0.1.0",
  "description": "Vendor-neutral control layer for agentic development — shared memory, coordination, MCP-first",
  "type": "module",
  "bin": {
    "chinwag": "./dist/cli.js"
  },
  "scripts": {
    "build": "esbuild cli.jsx --bundle --platform=node --format=esm --outfile=dist/cli.js --external:ink --external:react --external:ink-text-input --external:node-pty --banner:js='#!/usr/bin/env node' && chmod +x dist/cli.js",
    "dev": "npm run build && node dist/cli.js",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chinwag/shared": "file:../shared",
    "chalk": "^5.6.2",
    "chinwag-mcp": "file:../mcp",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "cli",
    "ai",
    "agents",
    "cursor",
    "claude",
    "coordination",
    "developer-tools"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.4"
  }
}
