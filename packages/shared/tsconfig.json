{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2024"],
    "types": ["node"],
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "./*.js",
    "./*.ts",
    "./contracts/*.ts",
    "./analytics/*.ts",
    "./__tests__/**/*.js",
    "./__tests__/**/*.ts"
  ],
  "exclude": ["./dist", "./node_modules"]
}
